NEXT_PUBLIC_CONTACT_EMAIL=

# WhatsApp Business (obrigatório para botões de WhatsApp)
# Número com DDI e DDD, apenas dígitos. Ex: 5511999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Google Analytics 4 (opcional)
NEXT_PUBLIC_GA_ID=

# Google Tag Manager (opcional)
NEXT_PUBLIC_GTM_ID=

# Hugging Face Inference API token (obrigatório para o chat Oráculo)
# Obtenha em: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Upstash Redis (opcional — rate limiting distribuído)
# Crie um banco Redis grátis em https://console.upstash.com
# Sem essas vars, o rate limit cai para in-memory (não distribuído)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
