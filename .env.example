NEXT_PUBLIC_CONTACT_EMAIL=

# WhatsApp Business (obrigatório para botões de WhatsApp)
# Número com DDI e DDD, apenas dígitos. Ex: 5511999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Google Analytics 4 (opcional)
NEXT_PUBLIC_GA_ID=

# Google Tag Manager (opcional)
NEXT_PUBLIC_GTM_ID=

# Hugging Face Inference API token (obrigatório para o chat Oráculo)
# Obtenha em: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Supabase (obrigatório para leads e rate limiting distribuído)
# Project Settings → API → Project URL + anon public key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Search Console (opcional — meta tag de verificação)
# Cole o código de verificação fornecido pelo Search Console
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# Notificação de leads por e-mail (opcional)
# SMTP — qualquer provedor (Gmail, Outlook, SendGrid, etc.)
# Se não configurado, notificações são ignoradas
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Para quem enviar a notificação
NOTIFY_EMAIL=
